{
  "name": "pressure",
  "version": "2.2.0",
  "description": "Pressure is a lightweight JavaScript library for Pointer Pressure, 3D Touch, and Force Touch through a single API.",
  "type": "module",
  "main": "dist/pressure.cjs",
  "module": "dist/pressure.js",
  "types": "dist/pressure.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pressure.js",
      "require": "./dist/pressure.cjs"
    },
    "./jquery": {
      "import": "./dist/jquery.pressure.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "rollup": "^4.62.2",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "build": "rollup -c && cp src/pressure.d.ts dist/pressure.d.ts",
    "prepare": "npm run build",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shelbeeely/pressure.git"
  },
  "keywords": [
    "pressure",
    "pressurejs",
    "pointer-pressure",
    "force-touch",
    "3d-touch",
    "apple-pencil",
    "stylus"
  ],
  "author": "Stuart Yamartino",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shelbeeely/pressure/issues"
  },
  "homepage": "https://github.com/shelbeeely/pressure#readme"
}
